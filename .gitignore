# AOS GitHub Upload .gitignore
# This .gitignore is for the upload directory only.

# IDE configs
.trae/
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo

# OS
Thumbs.db
.DS_Store

# AOS runtime data (should not exist in upload dir, but exclude as safety net)
04_MEMORY/credentials.json
04_MEMORY/user/
04_MEMORY/feedback/
05_CACHE/
06_LOGS/*/
!06_LOGS/README.md
08_INBOX/migration/
02_SANDBOX/*/
!02_SANDBOX/README.md
